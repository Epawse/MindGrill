# MindGrill 辩思 LLM Provider keys
#
# Copy this file to `.env.local` and fill in the keys you have. Only ONE key is
# strictly required for the app to function — `getDefaultProvider()` will pick
# whichever provider is configured first in the preference order
# (ollama-cloud → google → openai → anthropic → deepseek → qwen → glm → hunyuan → doubao).
#
# All providers are auto-detected at runtime; missing ones simply show as
# "未配置" in the UI and are skipped by the fallback router.

# === Pass 1.5 — LLM providers ===

# OpenAI (gpt-4o, gpt-4.1)
OPENAI_API_KEY=

# Anthropic Claude (claude-3.5-sonnet, claude-3.5-haiku)
ANTHROPIC_API_KEY=

# Google AI Studio / Gemini (gemini-2.5-flash, gemini-2.5-pro)
GOOGLE_GENERATIVE_AI_API_KEY=

# Ollama Cloud Pro (project's recommended primary provider).
# Base URL is configurable; defaults to https://ollama.com/v1
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=

# 通义千问 / Qwen (DashScope OpenAI-compatible mode)
QWEN_API_KEY=

# 智谱 GLM-4
GLM_API_KEY=

# 腾讯混元
HUNYUAN_API_KEY=

# 字节豆包 / Volcengine ARK
DOUBAO_API_KEY=

# Custom OpenAI-compatible gateway (NewAPI / Vercel AI Gateway / self-hosted).
# Both the URL and the key are required if you want to enable this provider.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Optionally pin a default provider id (must be one of the keys above that's
# actually configured). Falls back to the preference order if unset.
NEXT_PUBLIC_DEFAULT_PROVIDER=

# === Pass 2 — Auth / Persistence (Supabase, optional) ===
#
# Anonymous flow keeps working without these. Set both to enable Magic Link /
# Google login + the "我的拷问历史" page.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Pass 2 — MCP tool layer (optional) ===
#
# 辩思's architecture supports any MCP server. The default `tavily` server is
# auto-registered when you set TAVILY_API_KEY; add additional servers with
# MCP_SERVERS as a JSON array.
#
# Real tool invocation is gated on Vercel AI SDK v6 (`@ai-sdk/mcp`). Until v6
# is GA the layer is wired but inert: `getMcpTools()` returns {}. Setting
# these env vars is safe.
TAVILY_API_KEY=
# Example: MCP_SERVERS=[{"name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}]
MCP_SERVERS=

#
